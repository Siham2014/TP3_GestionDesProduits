<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>GESTION_PRODUITS</display-name>
  <welcome-file-list>
    <welcome-file>register.jsp</welcome-file>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.htm</welcome-file>
    <welcome-file>index.xhtml</welcome-file>
    <welcome-file>default.html</welcome-file>
    <welcome-file>default.jsp</welcome-file>
    <welcome-file>default.htm</welcome-file>
    <welcome-file>default.xhtml</welcome-file>
     
  </welcome-file-list>
  <servlet>
        <servlet-name>list</servlet-name> <!-- nom logique de la servlet -->
        <servlet-class>web.ListProduitServlet</servlet-class> <!-- classe Java correspondante -->
   </servlet>
   <servlet-mapping>
        <servlet-name>list</servlet-name>
        <url-pattern>/listProduits</url-pattern> <!-- URL pour accéder à cette servlet -->
    </servlet-mapping>

    <!-- Déclaration de la servlet qui ajoute un produit -->
    <servlet>
        <servlet-name>add</servlet-name>
        <servlet-class>web.AddProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>add</servlet-name>
        <url-pattern>/addProduit</url-pattern>
    </servlet-mapping>
        <!-- Déclaration de la servlet qui supprime un produit -->
    <servlet>
        <servlet-name>delete</servlet-name>
        <servlet-class>web.DeleteProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>delete</servlet-name>
        <url-pattern>/deleteProduit</url-pattern>
    </servlet-mapping>

    
    <servlet>
        <servlet-name>edit</servlet-name>
        <servlet-class>web.EditProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>edit</servlet-name>
        <url-pattern>/editProduit</url-pattern>
    </servlet-mapping>
       
    <servlet>
        <servlet-name>update</servlet-name>
        <servlet-class>web.UpdateProduitServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>update</servlet-name>
        <url-pattern>/updateProduit</url-pattern>
    </servlet-mapping>
    <servlet>
    <servlet-name>register</servlet-name>
    <servlet-class>web.RegisterServlet</servlet-class>
	</servlet>
	
	<servlet-mapping>
	    <servlet-name>register</servlet-name>
	    <url-pattern>/register</url-pattern>
	</servlet-mapping>
	
	
     <servlet>
    <servlet-name>login</servlet-name>
    <servlet-class>web.LoginServlet</servlet-class>
    </servlet>

	<servlet-mapping>
	    <servlet-name>login</servlet-name>
	    <url-pattern>/login</url-pattern>
	</servlet-mapping>
	<servlet>
    <servlet-name>logout</servlet-name>
    <servlet-class>web.LogoutServlet</servlet-class>
	</servlet>
	
	<servlet-mapping>
	    <servlet-name>logout</servlet-name>
	    <url-pattern>/logout</url-pattern>
	</servlet-mapping>
	  
		  
	<filter>
	    <filter-name>authFilter</filter-name>
	    <filter-class>web.AuthFilter</filter-class>
	</filter>
	
	<filter-mapping>
    <filter-name>authFilter</filter-name>
    <url-pattern>/listProduits</url-pattern>
	</filter-mapping>
	<filter-mapping>
	    <filter-name>authFilter</filter-name>
	    <url-pattern>/addProduit</url-pattern>
	</filter-mapping>
	<filter-mapping>
	    <filter-name>authFilter</filter-name>
	    <url-pattern>/editProduit</url-pattern>
	</filter-mapping>
	<filter-mapping>
	    <filter-name>authFilter</filter-name>
	    <url-pattern>/updateProduit</url-pattern>
	</filter-mapping>
	<filter-mapping>
	    <filter-name>authFilter</filter-name>
	    <url-pattern>/deleteProduit</url-pattern>
	</filter-mapping>
	<filter-mapping>
	    <filter-name>authFilter</filter-name>
	    <url-pattern>/logout</url-pattern>
	</filter-mapping>
	
	
	<filter>
	    <filter-name>adminFilter</filter-name>
	    <filter-class>web.AdminFilter</filter-class>
	</filter>
	
	<filter-mapping>
    <filter-name>adminFilter</filter-name>
    <url-pattern>/addProduit</url-pattern>
	</filter-mapping>
	
	<filter-mapping>
	    <filter-name>adminFilter</filter-name>
	    <url-pattern>/editProduit</url-pattern>
	</filter-mapping>
	
	<filter-mapping>
	    <filter-name>adminFilter</filter-name>
	    <url-pattern>/updateProduit</url-pattern>
	</filter-mapping>
	
	<filter-mapping>
	    <filter-name>adminFilter</filter-name>
	    <url-pattern>/deleteProduit</url-pattern>
	</filter-mapping>
	<error-page>
    <error-code>404</error-code>
    <location>/WEB-INF/errors/Error404.html</location>
	</error-page>
	
	<error-page>
	    <error-code>500</error-code>
	    <location>/WEB-INF/errors/Error500.html</location>
	</error-page>
	
	<error-page>
	    <exception-type>java.lang.Throwable</exception-type>
	    <location>/WEB-INF/errors/Exception.html</location>
	</error-page>
</web-app>